#include <winres.h>

IDI_APP_ICON ICON "@VEYOFF_ICON_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @VEYOFF_VERSION_MAJOR@,@VEYOFF_VERSION_MINOR@,@VEYOFF_VERSION_PATCH@,@VEYOFF_VERSION_BUILD@
 PRODUCTVERSION @VEYOFF_VERSION_MAJOR@,@VEYOFF_VERSION_MINOR@,@VEYOFF_VERSION_PATCH@,@VEYOFF_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "Microck\0"
            VALUE "FileDescription", "veyoff windows proxy\0"
            VALUE "FileVersion", "@VEYOFF_FILE_VERSION_STR@\0"
            VALUE "InternalName", "veyoff-windows.exe\0"
            VALUE "OriginalFilename", "veyoff-windows.exe\0"
            VALUE "ProductName", "veyoff\0"
            VALUE "ProductVersion", "@VEYOFF_VERSION_CLEAN@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
